{
    "extends": [
        "./with-check-strict.json",
        "./with-app.json"
    ],
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "lib": ["esnext", "dom", "dom.iterable", "webworker"],
        "module": "esnext",
        "moduleDetection": "auto",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "target": "esnext"
    }
}
